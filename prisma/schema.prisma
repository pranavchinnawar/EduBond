generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
}

model User {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  university      String
  email           String   @unique
  emailVerified   Boolean  @default(false)
  passwordHash    String
  avatarUrl       String?
  bio             String?
  major           String?
  year            String?  // Freshman, Sophomore, Junior, Senior
  reputationScore Float    @default(0.0)
  tokenBalance    Int      @default(50) // Starting token balance for new users
  role            String   @default("student") // student | admin
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  skillsToTeach   UserSkillToTeach[]
  skillsToLearn   UserSkillToLearn[]

  givenReviews    Review[] @relation("Reviewer")
  receivedReviews Review[] @relation("Reviewee")

  badges          UserBadge[]
  matches1        Match[]  @relation("MatchUser1")
  matches2        Match[]  @relation("MatchUser2")

  sentMessages     Message[] @relation("MessageSender")
  receivedMessages Message[] @relation("MessageReceiver")

  tokenLedger     TokenTransaction[]
}

model Skill {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  name     String @unique
  category String
}

model UserSkillToTeach {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  userId      String @db.ObjectId
  skill       String
  proficiency String @default("intermediate") // beginner, intermediate, advanced, expert
  user        User   @relation(fields: [userId], references: [id])
}

model UserSkillToLearn {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  skill  String
  user   User   @relation(fields: [userId], references: [id])
}

model Match {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  user1Id   String   @db.ObjectId
  user2Id   String   @db.ObjectId
  status    String   // PENDING, ACCEPTED, REJECTED, COMPLETED
  createdAt DateTime @default(now())

  sessions  Session[]
  messages  Message[]
  user1     User   @relation("MatchUser1", fields: [user1Id], references: [id])
  user2     User   @relation("MatchUser2", fields: [user2Id], references: [id])
}

model Session {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  matchId       String   @db.ObjectId
  scheduledAt   DateTime
  durationMin   Int
  status        String   @default("scheduled") // scheduled, completed, cancelled
  tokensCost    Int      @default(10) // Tokens exchanged for this session
  createdAt     DateTime @default(now())
  match         Match    @relation(fields: [matchId], references: [id])
}

model Review {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  reviewerId String   @db.ObjectId
  revieweeId String   @db.ObjectId
  rating     Int      // 1 to 5
  comment    String?
  createdAt  DateTime @default(now())
  reviewer   User     @relation("Reviewer", fields: [reviewerId], references: [id])
  reviewee   User     @relation("Reviewee", fields: [revieweeId], references: [id])
}

model Message {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  matchId    String   @db.ObjectId
  senderId   String   @db.ObjectId
  receiverId String   @db.ObjectId
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  match      Match    @relation(fields: [matchId], references: [id])
  sender     User     @relation("MessageSender", fields: [senderId], references: [id])
  receiver   User     @relation("MessageReceiver", fields: [receiverId], references: [id])
}

model TokenTransaction {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  amount      Int      // positive = earned, negative = spent
  reason      String   // "teaching_session", "learning_session", "signup_bonus", "badge_reward"
  sessionId   String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model Badge {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  iconEmoji   String
  description String
  criteria    String // JSON string defining auto-award criteria
}

model UserBadge {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  badgeId   String   @db.ObjectId
  awardedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
